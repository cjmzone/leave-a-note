# Cloudflare account identifier
CLOUDFLARE_ACCOUNT_ID=YOUR_ACCOUNT_ID

# Cloudflare API token with D1 query access for the target database
CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN

# D1 database id for Leave a Note
CLOUDFLARE_D1_DATABASE_ID=YOUR_D1_DATABASE_ID

# R2 S3-compatible credentials (R2 API Tokens)
CLOUDFLARE_R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
CLOUDFLARE_R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY

# R2 bucket name used by uploads
CLOUDFLARE_R2_BUCKET=post-images

# Public base URL used to render uploaded images in the feed
# Example: https://pub-<hash>.r2.dev
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://YOUR-R2-PUBLIC-BASE-URL

# Salt for hashing client IPs before storing rate-limit records
IP_HASH_SALT=replace-with-a-long-random-string
